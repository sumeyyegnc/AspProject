@model AspProject.Models.Sehir
@{
    ViewData["Title"] = "Edit";
}
<h1>Edit</h1>
<h4>Sehirler</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="SehirNo" />
            <div class="form-group">
                <label asp-for="SehirAdi" class="control-label"></label>
                <input asp-for="SehirAdi" class="form-control" />
                <span asp-validation-for="SehirAdi" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Plaka" class="control-label"></label>
                <input asp-for="Plaka" class="form-control" />
                <span asp-validation-for="Plaka" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
<div>
    <a asp-action="Index">Back to List</a>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}