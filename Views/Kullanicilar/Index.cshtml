@model IEnumerable<AspProject.Models.Kullanici>

@{
    ViewData["Title"] = "Kullanıcı Listesi";
}

<div class="container mt-3">

    <h2 class="mb-3">👤 Kullanıcı Listesi</h2>
    <div class="mb-3 d-flex gap-2">

        <a asp-controller="Kullanicilar" asp-action="ExportToPdf" class="btn btn-danger">
            <i class="fa fa-file-pdf-o"></i> PDF İndir
        </a>

        <a asp-controller="Kullanicilar" asp-action="ExportToExcel" class="btn btn-success">
            <i class="fa fa-file-excel-o"></i> Excel İndir
        </a>

    </div>
    <!-- ÜST BUTON -->
    <a asp-action="Create" class="btn btn-primary mb-3">
        + Yeni Kullanıcı
    </a>

    <!-- ARAMA -->
    <form asp-action="Index" method="get" class="mb-3">
        <div class="input-group">
            <input type="text"
                   name="searchString"
                   class="form-control"
                   placeholder="Kullanıcı ara..." />

            <button type="submit" class="btn btn-outline-primary">
                🔎 Ara
            </button>
        </div>
    </form>

    <!-- TABLO -->
    <div class="table-responsive">
        <table class="table table-hover table-bordered shadow-sm">

            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.KullaniciAdi)</th>
                    <th>@Html.DisplayNameFor(model => model.Mail)</th>
                    <th style="width:200px;">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.KullaniciAdi</td>
                        <td>@item.Mail</td>

                        <td>
                            <a asp-action="Edit"
                               asp-route-id="@item.KullaniciId"
                               class="btn btn-sm btn-success">
                                ✏️ Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.KullaniciId"
                               class="btn btn-sm btn-danger"
                               onclick="return confirm('Silmek istediğinize emin misiniz?');">
                                🗑 Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>

</div>