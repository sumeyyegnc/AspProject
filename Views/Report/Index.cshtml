@model IEnumerable<AspProject.Models.urunsehirlistview>

<table class="table table-bordered">
	<thead>
		<tr>
			<th>Ürün Adı</th>
			<th>Fiyat</th>
			<th>Stok</th>
			<th>Şehir Adı</th>
		</tr>
	</thead>

	<tbody>
		@foreach (var item in Model)
		{
			<tr>
				<td>@item.UrunAdi</td>
				<td>@item.Fiyati</td>
				<td>@item.Stok</td>
				<td>@item.SehirAdi</td>
			</tr>
		}
	</tbody>
</table>